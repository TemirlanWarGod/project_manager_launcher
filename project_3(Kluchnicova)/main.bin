#include <iostream>
using namespace std;

int** findUpingSequences(int* inArr, int inSize, int& outCount) {

    if (inSize <= 0) {
        outCount = 0;
        return nullptr;
    }

    outCount = 0;
    for (int i = 0; i < inSize; ) {
        outCount++;
        while (i + 1 < inSize && inArr[i + 1] > inArr[i]) {
            i++;
        }
        i++;
    }
    int** result = new int* [outCount];
    int currentSeq = 0;
    for (int i = 0; i < inSize; ) {
        int startSeq = i;
        while (i + 1 < inSize && inArr[i + 1] > inArr[i]) {
            i++;
        }
        int length = (i - startSeq + 1) + 1;

        result[currentSeq] = new int[length];
        result[currentSeq][0] = length - 1;


        for (int j = 0; j < length; j++) {
            result[currentSeq][j + 1] = inArr[startSeq + j];
        }

        currentSeq++;
        i++;
    }
    return result;
}

int main() {
    int size;
    cout << "Enter size Array: ";
    cin >> size;
    int* arr = new int[size];

    cout << "Enter " << size << " elemets:" << endl;
    for (int i = 0; i < size; i++) {
        cin >> arr[i];
    }

    int count = 0;//Количество последовательностей
    int** sequences = findUpingSequences(arr, size, count);

    cout << "\nFinding group's: " << count << endl;
    for (int i = 0; i < count; i++) {
        int len = sequences[i][0];
        cout << "Group " << i + 1 << " (size " << len << "): ";
        for (int j = 1; j <= len; j++) {
            cout << sequences[i][j] << " ";
        }
        cout << endl;
    }

    for (int i = 0; i < count; i++) {
        delete[] sequences[i];
    }
    delete[] sequences;
    delete[] arr;
    system("pause");
}